# Resend — contact form email delivery (https://resend.com)
# Copy this file to .env.local and fill in the values.

# 1. Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address shown on outgoing mail. For the visitor auto-reply to actually
# deliver, this MUST be on a domain you've verified at resend.com/domains.
# Before verifying, you can use "Keenan Fernandes <onboarding@resend.dev>",
# but that can only deliver to YOUR OWN Resend account email.
EMAIL_FROM="Keenan Fernandes <keenan@codingbarista.com>"

# Inbox that receives the inquiry notifications (your real mailbox).
EMAIL_TO=keenan030900@gmail.com

# Set to "true" ONLY after your sending domain is verified at resend.com/domains.
# When true, visitors also receive the "I'll be in touch within a few hours" auto-reply.
# Leave "false" until verified, or the auto-reply send will fail.
RESEND_DOMAIN_VERIFIED=false
